datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  OWNER
  STAFF
}

enum ShopType {
  MAIN
  BRANCH
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE
}

enum InventoryTxnType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  TRANSFER // Added transfer type
}

enum SaleStatus {
  COMPLETED
  REFUNDED
}

enum TransferStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ------------------------------------------------------
// MULTI-TENANCY (Agrovet Businesses)
// ------------------------------------------------------

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  email       String   @unique
  phoneNumber String?
  createdAt   DateTime @default(now())

  // Core entities strictly isolated per organization
  users     User[]
  shops     Shop[]
  products  Product[]
  suppliers Supplier[]
}

// ------------------------------------------------------
// USERS & ACCESS CONTROL
// ------------------------------------------------------

model User {
  id             String   @id @default(uuid())
  firebaseUid    String?  @unique
  organizationId String? // Optional because SUPER_ADMIN doesn't belong to any org
  name           String
  email          String   @unique
  passwordHash   String?
  role           Role // SUPER_ADMIN, OWNER, ADMIN, STAFF
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  // Shops owned by this user (owner relationship)
  shopsOwned    Shop[]
  staffIn       ShopStaff[]

  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  deviceId   String?
  clientType String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  isRevoked  Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])
}

model TokenBlocklist {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ------------------------------------------------------
// SHOPS & BRANCHES
// ------------------------------------------------------

model Shop {
  id             String   @id @default(uuid())
  organizationId String
  type           ShopType @default(MAIN)
  name           String
  location       String?

  // Branching hierarchy
  // Rule: MAIN shops have parentId = null. 
  // Rule: BRANCH shops MUST have a valid parentId pointing to a MAIN shop. 
  // Rule: A BRANCH cannot have its own branches (1-level deep only).
  // Owner of this shop (user who owns/created it)
  ownerId   String
  parentId  String?
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User        @relation(fields: [ownerId], references: [id])
  parent       Shop?        @relation("ShopToBranches", fields: [parentId], references: [id])
  branches     Shop[]       @relation("ShopToBranches")

  staff       ShopStaff[]
  inventories Inventory[]
  sales       Sale[]
  purchases   Purchase[]
  expenses    Expense[]

  inventoryTransactions InventoryTransaction[]
  transfersOut          InventoryTransfer[]    @relation("TransferFrom")
  transfersIn           InventoryTransfer[]    @relation("TransferTo")
}

model ShopStaff {
  id     String @id @default(uuid())
  shopId String
  userId String
  role   String // e.g., MANAGER, CASHIER

  shop Shop @relation(fields: [shopId], references: [id])
  user User @relation(fields: [userId], references: [id])

  // A user can be assigned to multiple branches, but only once per branch
  @@unique([shopId, userId])
}

// ------------------------------------------------------
// PRODUCT CATALOG (Agrovet Specific)
// ------------------------------------------------------

model Category {
  id   String @id @default(uuid())
  name String

  products Product[]
}

model Product {
  id             String  @id @default(uuid())
  organizationId String
  categoryId     String?

  name        String
  description String?

  // Agrovet specific fields
  unit         String? // kg, liter, piece, etc.
  dosageInfo   String? // specific dosage for drugs/pesticides
  manufacturer String?
  isRestricted Boolean @default(false) // e.g. regulated chemicals

  // Image handling
  imageUrl     String? // URL to access the image
  imagePath    String? // File path in volume
  imageMimeType String? // e.g., image/jpeg, image/png

  createdAt DateTime @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  category     Category?        @relation(fields: [categoryId], references: [id])
  variants     ProductVariant[]
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  name      String // e.g. "500ml", "1kg"
  sku       String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])

  inventory             Inventory[]
  inventoryTransactions InventoryTransaction[]
  purchaseItems         PurchaseItem[]
  saleItems             SaleItem[]
  transferItems         InventoryTransferItem[]

  // SKU must be unique across the entire system, or alternatively unique per organization.
  // Assuming global SKU uniqueness for barcode scanners, but per-tenant is often preferred.
  @@unique([sku])
}

// ------------------------------------------------------
// INVENTORY & STOCK
// ------------------------------------------------------

model Inventory {
  id        String @id @default(uuid())
  shopId    String
  variantId String

  // FEFO Support (First Expiry First Out)
  batchNumber String    @default("DEFAULT")
  expiryDate  DateTime?

  quantity     Int      @default(0)
  costPrice    Float
  sellingPrice Float
  updatedAt    DateTime @updatedAt

  shop    Shop           @relation(fields: [shopId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])

  // Stock is uniquely tracked per shop, variant, AND batch
  @@unique([shopId, variantId, batchNumber])
}

model InventoryTransaction {
  id        String           @id @default(uuid())
  shopId    String
  variantId String
  type      InventoryTxnType

  batchNumber String? // Which batch was affected
  quantity    Int // Positive or negative based on transaction type
  referenceId String? // ID of purchase, sale, or transfer
  createdAt   DateTime @default(now())

  shop    Shop           @relation(fields: [shopId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model InventoryTransfer {
  id         String         @id @default(uuid())
  fromShopId String
  toShopId   String
  status     TransferStatus @default(PENDING)
  createdAt  DateTime       @default(now())
  createdBy  String // User ID who initiated transfer

  // Rule: fromShop and toShop MUST belong to the same organization
  fromShop Shop @relation("TransferFrom", fields: [fromShopId], references: [id])
  toShop   Shop @relation("TransferTo", fields: [toShopId], references: [id])

  items InventoryTransferItem[]
}

model InventoryTransferItem {
  id          String @id @default(uuid())
  transferId  String
  variantId   String
  batchNumber String @default("DEFAULT")
  quantity    Int

  transfer InventoryTransfer @relation(fields: [transferId], references: [id])
  variant  ProductVariant    @relation(fields: [variantId], references: [id])
}

// ------------------------------------------------------
// PURCHASING & SUPPLIERS
// ------------------------------------------------------

model Supplier {
  id             String  @id @default(uuid())
  organizationId String
  name           String
  contact        String?

  // Agrovet specific
  licenseNumber String?
  region        String?

  organization Organization @relation(fields: [organizationId], references: [id])
  purchases    Purchase[]
}

model Purchase {
  id          String   @id @default(uuid())
  shopId      String
  supplierId  String?
  totalAmount Float
  createdBy   String
  createdAt   DateTime @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  items PurchaseItem[]
}

model PurchaseItem {
  id          String    @id @default(uuid())
  purchaseId  String
  variantId   String
  batchNumber String? // Batch details received
  expiryDate  DateTime?
  quantity    Int
  costPrice   Float

  purchase Purchase       @relation(fields: [purchaseId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])
}

// ------------------------------------------------------
// SALES & PAYMENTS
// ------------------------------------------------------

model Sale {
  id        String     @id @default(uuid())
  shopId    String
  subtotal  Float
  discount  Float      @default(0)
  tax       Float      @default(0)
  total     Float
  status    SaleStatus @default(COMPLETED)
  createdBy String
  createdAt DateTime   @default(now())

  shop Shop @relation(fields: [shopId], references: [id])

  items    SaleItem[]
  payments Payment[]
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  variantId   String
  batchNumber String? // Which batch was sold (for FEFO auditing)
  quantity    Int
  price       Float

  sale    Sale           @relation(fields: [saleId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
}

model Payment {
  id     String        @id @default(uuid())
  saleId String
  amount Float
  method PaymentMethod

  sale Sale @relation(fields: [saleId], references: [id])
}

// ------------------------------------------------------
// ACCOUNTING & AUDIT
// ------------------------------------------------------

model Expense {
  id       String   @id @default(uuid())
  shopId   String
  title    String
  amount   Float
  category String?
  date     DateTime

  shop Shop @relation(fields: [shopId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
